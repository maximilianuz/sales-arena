rules_version = '2';

// Reglas de Storage para las imágenes de las Propuestas VIP.
// Desplegar con:  firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {

    // Imágenes de propuestas: lectura pública (el prospecto las ve en el link
    // /p/:id), pero solo el dueño autenticado puede subir/borrar las suyas.
    match /proposalMedia/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024   // 10MB máx
                   && request.resource.contentType.matches('image/.*');
    }

    // Todo lo demás queda cerrado por defecto.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

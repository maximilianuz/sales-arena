# ============================================
# NVIDIA LLM Configuration (Dual API - Equipment Mode)
# ============================================
# Reemplaza FLOWISE con NVIDIA como proveedor principal
# Soporta 2 APIs de NVIDIA con modelos diferentes

# ============================================
# NVIDIA #1 (Primary API)
# ============================================
NVIDIA_API_KEY=your_nvidia_api_key_1_here
NVIDIA_URL=https://integrate.api.nvidia.com/v1/chat/completions

# NVIDIA #1 Model Selection (Optional - Overrides defaults)
# Default Fast: meta/llama-3.1-8b-instruct
# Default Smart: meta/llama-3.1-70b-instruct
#
# NVIDIA_MODEL_FAST=meta/llama-3.1-8b-instruct
# NVIDIA_MODEL_SMART=meta/llama-3.1-70b-instruct

# ============================================
# NVIDIA #2 (Secondary API - Optional)
# ============================================
# Descomentar para usar segunda API de NVIDIA
# Si se agota NVIDIA #1, automáticamente usa NVIDIA #2
#
# NVIDIA_API_KEY_2=your_nvidia_api_key_2_here
# NVIDIA_URL_2=https://integrate.api.nvidia.com/v1/chat/completions
#
# NVIDIA #2 Model Selection (Optional - Overrides defaults)
# Default Fast: meta/llama-3.2-3b-instruct (más rápido)
# Default Smart: meta/llama-3.3-70b-instruct (versión mejorada)
#
# NVIDIA_2_MODEL_FAST=meta/llama-3.2-3b-instruct
# NVIDIA_2_MODEL_SMART=meta/llama-3.3-70b-instruct

# ============================================
# Groq Configuration (Fallback Provider)
# ============================================
# Si NVIDIA no está disponible, automáticamente usa Groq

GROQ_API_KEY=your_groq_api_key_here
# GROQ_URL=https://api.groq.com/openai/v1/chat/completions (default)
# GROQ_MODEL_FAST=llama-3.1-8b-instant (default)
# GROQ_MODEL_SMART=llama-3.3-70b-versatile (default)

# ============================================
# DESACTIVADO: Flowise (Anterior Proveedor)
# ============================================
# Flowise ha sido reemplazado por NVIDIA
# Las siguientes variables ya no son necesarias:
#
# FLOWISE_URL=...
# FLOWISE_API_KEY=...
# FLOWISE_CHATFLOW_ID=...

# ============================================
# LLM Configuration
# ============================================
# LLM_DISABLE_JSON_MODE=false

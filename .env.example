# Environment example

Copy this file to `.env.local` and fill values with your Firebase / provider credentials. DO NOT commit real secrets.

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Payment / AI providers (placeholders)
VITE_STRIPE_PUBLIC_KEY=pk_test_xxx
VITE_NVIDIA_API_KEY=your_nvidia_key
VITE_OPENAI_KEY=your_openai_key

# Server-side Firebase Admin SDK (for Netlify functions)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_service_account_email
FIREBASE_PRIVATE_KEY=your_firebase_service_account_private_key
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Admin setup (for initial configuration)
SETUP_SECRET_TOKEN=your_secret_token_for_admin_setup

# LLM Providers Chain: NVIDIA #1 → NVIDIA #2 → Groq (fallback)
# For equipment management functionality

# NVIDIA #1 (Primary with fast/small model)
NVIDIA_API_KEY=your_nvidia_api_key_1
NVIDIA_URL=https://integrate.api.nvidia.com/v1/chat/completions
# Optional model overrides:
# NVIDIA_MODEL_FAST=meta/llama-3.1-8b-instruct (default)
# NVIDIA_MODEL_SMART=meta/llama-3.1-70b-instruct (default)

# NVIDIA #2 (Secondary with different model/key)
# Uncomment to enable second NVIDIA instance
# NVIDIA_API_KEY_2=your_nvidia_api_key_2
# NVIDIA_URL_2=https://integrate.api.nvidia.com/v1/chat/completions
# Optional model overrides for NVIDIA #2:
# NVIDIA_2_MODEL_FAST=meta/llama-3.2-3b-instruct (default)
# NVIDIA_2_MODEL_SMART=meta/llama-3.3-70b-instruct (default)

# Groq (Final fallback)
GROQ_API_KEY=your_groq_api_key
GROQ_URL=https://api.groq.com/openai/v1/chat/completions
# GROQ_MODEL_FAST=llama-3.1-8b-instant
# GROQ_MODEL_SMART=llama-3.3-70b-versatile

# ── Voz del lead (Fish Audio TTS) ────────────────────────────────────────────
FISH_AUDIO_API_KEY=your_fish_audio_api_key
# FISH_MODEL=s2.1-pro-free   # (default; el server reintenta con s2-pro si falla)
#
# Voice models por idioma/género/personalidad → timbre FIJO y del género correcto
# entre turnos. Descubrí IDs con: FISH_AUDIO_API_KEY=... node scripts/find-fish-voices.js
# Con solo el default por género (male/female) por idioma ya alcanza:
# FISH_VOICE_ES_MALE=voice_id
# FISH_VOICE_ES_FEMALE=voice_id
# FISH_VOICE_EN_MALE=voice_id
# FISH_VOICE_EN_FEMALE=voice_id
# Opcionales por perfil DISC (directivo|entusiasta|empatico|analitico):
# FISH_VOICE_ES_MALE_DIRECTIVO=voice_id
# FISH_VOICE_ES_FEMALE_EMPATICO=voice_id
# ... (mismo patrón para EN)

# Environment example

Copy this file to `.env.local` and fill values with your Firebase / provider credentials. DO NOT commit real secrets.

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Payment / AI providers (placeholders)
VITE_STRIPE_PUBLIC_KEY=pk_test_xxx
VITE_NVIDIA_API_KEY=your_nvidia_key
VITE_OPENAI_KEY=your_openai_key

# Server-side Firebase Admin SDK (for Netlify functions)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_service_account_email
FIREBASE_PRIVATE_KEY=your_firebase_service_account_private_key
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Admin setup (for initial configuration)
SETUP_SECRET_TOKEN=your_secret_token_for_admin_setup

# LLM Providers Chain: NVIDIA (primary) → Groq (fallback)
# For equipment management functionality
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_URL=https://integrate.api.nvidia.com/v1/chat/completions
# Optional model overrides:
# NVIDIA_MODEL_FAST=meta/llama-3.1-8b-instruct
# NVIDIA_MODEL_SMART=meta/llama-3.1-70b-instruct

GROQ_API_KEY=your_groq_api_key
GROQ_URL=https://api.groq.com/openai/v1/chat/completions
# GROQ_MODEL_FAST=llama-3.1-8b-instant
# GROQ_MODEL_SMART=llama-3.3-70b-versatile

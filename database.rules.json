{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        "subscriptionStatus": {
          ".write": "$uid === auth.uid"
        },
        "country": {
          ".write": "$uid === auth.uid"
        },
        "subscriptionPlan": {
          ".write": false
        },
        "sessionsUsed": {
          ".write": false
        },
        "subscriptionExpiry": {
          ".write": false
        },
        "subscriptionProvider": {
          ".write": false
        }
      }
    },
    "history": {
      "$sessionId": {
        ".read": "$uid === auth.uid",
        ".write": false
      }
    },
    "library": {
      ".write": "$uid === auth.uid"
    },
    "cohorts": {
      "$trainerUid": {
        ".read": "$trainerUid === auth.uid",
        ".write": false
      }
    },
    "cohortCodes": {
      ".read": false,
      ".write": false
    },
    "leaderboard": {
      ".read": "auth != null",
      ".write": false
    },
    "scouting": {
      "profiles": {
        "$uid": {
          ".read": "$uid === auth.uid",
          ".write": "$uid === auth.uid"
        }
      }
    },
    "telemetry": {
      ".write": "auth != null",
      ".validate": "newData.hasChild('type')"
    },
    "proposals": {
      ".read": true,
      "$proposalId": {
        ".write": "data.child('ownerUid').val() === auth.uid || newData.child('ownerUid').val() === auth.uid",
        ".validate": "newData.hasChild('ownerUid') && newData.hasChild('title')"
      }
    },
    "proposalIndex": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "proposalEvents": {
      "$proposalId": {
        ".read": "root.child('proposals').child($proposalId).child('ownerUid').val() === auth.uid",
        ".write": "!newData.exists()",
        ".validate": "newData.hasChild('t') && newData.hasChild('ts')"
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}

{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        "subscriptionStatus": {
          ".write": "$uid === auth.uid && newData.val() === 'free'"
        },
        "country": {
          ".write": "$uid === auth.uid && (newData.isString() && newData.val().length <= 2)"
        },
        "subscriptionPlan": { ".write": false },
        "sessionsUsed": { ".write": false },
        "subscriptionExpiry": { ".write": false },
        "subscriptionProvider": { ".write": false },
        "history": {
          "$sessionId": {
            ".read": "$uid === auth.uid",
            ".write": false
          }
        },
        "library": {
          ".write": "$uid === auth.uid"
        }
      }
    },
    "cohorts": {
      "$trainerUid": {
        ".read": "$trainerUid === auth.uid",
        ".write": false
      }
    },
    "cohortCodes": {
      ".read": false,
      ".write": false
    },
    "leaderboard": {
      ".read": "auth != null",
      ".write": false
    },
    "scouting": {
      "profiles": {
        "$uid": {
          ".read": "$uid === auth.uid",
          ".write": false
        }
      }
    },
    "telemetry": {
      ".read": false,
      "$day": {
        "$entry": {
          ".write": "auth != null",
          ".validate": "newData.hasChild('type')"
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}

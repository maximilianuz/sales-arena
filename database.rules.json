{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid && newData.child('subscriptionStatus').val() === 'free'"
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}

{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        "subscriptionStatus": {
          ".write": "$uid === auth.uid && newData.val() === 'free'"
        },
        "subscriptionPlan": { ".write": false },
        "sessionsUsed": { ".write": false },
        "subscriptionExpiry": { ".write": false },
        "subscriptionProvider": { ".write": false },
        "history": {
          "$sessionId": {
            ".read": "$uid === auth.uid",
            ".write": false
          }
        }
      }
    },
    "cohorts": {
      "$trainerUid": {
        ".read": "$trainerUid === auth.uid",
        ".write": false
      }
    },
    "cohortCodes": {
      ".read": false,
      ".write": false
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}

{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        "subscriptionStatus": {
          ".write": "$uid === auth.uid && newData.val() === 'free'"
        },
        "country": {
          ".write": "$uid === auth.uid && (newData.isString() && newData.val().length <= 2)"
        },
        "subscriptionPlan": { ".write": false },
        "sessionsUsed": { ".write": false },
        "subscriptionExpiry": { ".write": false },
        "subscriptionProvider": { ".write": false },
        "history": {
          "$sessionId": {
            ".read": "$uid === auth.uid",
            ".write": false
          }
        },
        "library": {
          ".write": "$uid === auth.uid"
        }
      }
    },
    "cohorts": {
      "$trainerUid": {
        ".read": "$trainerUid === auth.uid",
        ".write": false
      }
    },
    "cohortCodes": {
      ".read": false,
      ".write": false
    },
    "leaderboard": {
      ".read": "auth != null",
      ".write": false
    },
    "scouting": {
      "profiles": {
        "$uid": {
          ".read": "$uid === auth.uid",
          ".write": false
        }
      }
    },
    "telemetry": {
      ".read": false,
      "$day": {
        "$entry": {
          ".write": "auth != null",
          ".validate": "newData.hasChild('type')"
        }
      }
    },
    "proposals": {
      ".read": false,
      "$proposalId": {
        ".read": true,
        ".write": "auth != null && (!data.exists() || data.child('ownerUid').val() === auth.uid) && (!newData.exists() || newData.child('ownerUid').val() === auth.uid)",
        ".validate": "newData.hasChildren(['ownerUid', 'title'])"
      }
    },
    "proposalIndex": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "proposalEvents": {
      "$proposalId": {
        ".read": "auth != null && root.child('proposals').child($proposalId).child('ownerUid').val() === auth.uid",
        ".write": "auth != null && root.child('proposals').child($proposalId).child('ownerUid').val() === auth.uid && !newData.exists()",
        "$eventId": {
          ".write": "!data.exists()",
          ".validate": "newData.hasChildren(['t', 'ts'])"
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
